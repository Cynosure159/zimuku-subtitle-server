# Docker Compose test environment template
# Usage:
#   cp .env.test.example .env.test
#   docker compose --env-file .env.test up --build

TZ=Asia/Shanghai

# Avoid conflicting with local dev services
BACKEND_PORT=18000
FRONTEND_PORT=18080

# Keep test runtime data isolated from production storage
ZIMUKU_STORAGE_BIND=./.tmp/test-runtime/storage

# Test media library bind mounts
MEDIA_MOVIES_BIND=./.tmp/test-runtime/media/movies
MEDIA_TV_BIND=./.tmp/test-runtime/media/tv
MEDIA_MOVIES_MOUNT_MODE=rw
MEDIA_TV_MOUNT_MODE=rw

# More verbose logs for test and debugging
LOG_LEVEL=DEBUG
UVICORN_LOG_LEVEL=debug
ZIMUKU_LOG_FILE=/app/storage/test.log

# Optional backend overrides
ZIMUKU_BASE_URL=https://zimuku.org
ZIMUKU_PROXY=

# Leave empty to use /app/storage/zimuku.db inside the mounted storage root
ZIMUKU_DATABASE_URL=
ZIMUKU_DB_PATH=
ZIMUKU_DOWNLOAD_PATH=
ZIMUKU_TEMP_PATH=
ZIMUKU_EXTRACTED_PATH=

# Add media library paths in the app as:
#   /media/movies
#   /media/tv
# If you only need read-only scanning, set mount mode to ro.

# Slightly gentler network controls for integration-style testing
ZIMUKU_REQUEST_TIMEOUT_SECONDS=20
ZIMUKU_REQUEST_MAX_RETRIES=2
ZIMUKU_REQUEST_BACKOFF_SECONDS=1
ZIMUKU_REQUEST_MIN_INTERVAL_SECONDS=1
