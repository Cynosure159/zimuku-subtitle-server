# Docker Compose production environment template
# Usage:
#   cp .env.production.example .env.production
#   docker compose --env-file .env.production up -d

TZ=Asia/Shanghai

# Published ports on the host
BACKEND_PORT=8000
FRONTEND_PORT=80

# Optional published image names
BACKEND_IMAGE=cynosure159/zimuku-subtitle-server-backend:latest
FRONTEND_IMAGE=cynosure159/zimuku-subtitle-server-frontend:latest

# Host storage bind mount
ZIMUKU_STORAGE_BIND=./storage

# Host media library bind mounts
MEDIA_MOVIES_BIND=./media/movies
MEDIA_TV_BIND=./media/tv
MEDIA_MOVIES_MOUNT_MODE=rw
MEDIA_TV_MOUNT_MODE=rw

# Logging
LOG_LEVEL=INFO
UVICORN_LOG_LEVEL=info
ZIMUKU_LOG_FILE=/app/storage/app.log

# Optional backend overrides
ZIMUKU_BASE_URL=https://zimuku.org
ZIMUKU_PROXY=

# Frontend reverse proxy target
BACKEND_UPSTREAM=http://backend:8000

# Leave empty to use /app/storage/zimuku.db inside the mounted storage root
ZIMUKU_DATABASE_URL=
ZIMUKU_DB_PATH=
ZIMUKU_DOWNLOAD_PATH=
ZIMUKU_TEMP_PATH=
ZIMUKU_EXTRACTED_PATH=

# Add media library paths in the app as:
#   /media/movies
#   /media/tv
# If you only need read-only scanning, set mount mode to ro.

# Scraper runtime tuning
ZIMUKU_REQUEST_TIMEOUT_SECONDS=15
ZIMUKU_REQUEST_MAX_RETRIES=3
ZIMUKU_REQUEST_BACKOFF_SECONDS=1
ZIMUKU_REQUEST_MIN_INTERVAL_SECONDS=1
